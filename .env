#Your Timezone
TIMEZONE=America/Regina

#User ID, get it by running: id `whoami`
USER_ID=1000
GROUP_ID=1000

#OVERSEERR
OVERSEERR_PORT=5055

#RIVEN Frontend
#If behind a reverse proxy, do not set the origin (remove ORIGIN=${RIVEN_ORIGIN} from the docker-compose.yml file)
#If accessing riven directly, set it to whatever address:port you access it from. Not recommended to expose this to the internet as there's no security
#Default is if you are accessing it on your local machine
RIVEN_ORIGIN=http://localhost:3000

#Get a claim token from https://account.plex.tv/claim to automatically log the server into your Plex account
PLEX_CLAIM_TOKEN=xxxxxxxxxxxx

#REAL-DEBRID (Get your key from here: https://real-debrid.com/devices under "API Private Token")
REAL_DEBRID=xxxxxxxxxxxx

#DATABASE
PG_HOST=ups-database
PG_DATA=/var/lib/postgresql/data/pgdata
PG_USER=postgres
PG_PASSWORD=postgres
RIVEN_DB=riven
ZILEAN_DB=zilean

