#Your Timezone
TZ=America/Regina

#User ID, get it by running: id
USER_ID=1000
GROUP_ID=1000

#OVERSEERR
OVERSEERR_PORT=5055

#RIVEN Frontend
#If behind a reverse proxy, do not set the origin (remove ORIGIN=${RIVEN_ORIGIN} from the docker-compose.yml file)
#If accessing riven directly, set it to whatever address:port you access it from. Not recommended to expose this to the internet as there's no security
#Default is if you are accessing it on your local machine
#What port should the frontend be exposed on so you can access it?
RIVEN_PORT=3000
RIVEN_ORIGIN=http://localhost:$RIVEN_PORT

#Get a claim token from https://account.plex.tv/claim to automatically log the server into your Plex account
#Only needed the first run, but don't need to remove it from here
PLEX_CLAIM_TOKEN=xxxxxxxxxxxx
#Type of server. If you have a plex pass, change this to plexpass
PLEX_TYPE=public
PLEX_PORT=32400

#REAL-DEBRID (Get your key from here: https://real-debrid.com/devices under "API Private Token")
REAL_DEBRID=xxxxxxxxxxxx

#DATABASE
PG_HOST=ups-database
PG_DATA=/var/lib/postgresql/data/pgdata
PG_USER=postgres
PG_PASSWORD=postgres
RIVEN_DB=riven
ZILEAN_DB=zilean

#Folder paths
# The root path (if you change the above outside of /mnt, set it here)
ROOT_PATH=/mnt
# Where rclone mounts the zurg webdav
RCLONE_MNT=zurg
# Where riven makes symlinks and plex looks for content
LIBRARY_MNT=library

